# ──────────────────────────────────────────────────────────────
# VeriTruth AI — Environment Configuration
# ──────────────────────────────────────────────────────────────
# Copy to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# ──────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────
APP_NAME=VeriTruth AI
APP_ENV=development
DEBUG=true
API_VERSION=v1
API_PREFIX=/api/v1
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
SECRET_KEY=change-me-to-a-random-64-char-hex-string
ALLOWED_HOSTS=localhost,127.0.0.1

# ── JWT Authentication ───────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── PostgreSQL (Main DB) ────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=veritruth
POSTGRES_PASSWORD=change-me-pg-password
POSTGRES_DB=veritruth_db
DATABASE_URL=postgresql+asyncpg://veritruth:change-me-pg-password@localhost:5432/veritruth_db

# ── MongoDB (News Storage) ──────────────────────────────────
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USER=veritruth
MONGODB_PASSWORD=change-me-mongo-password
MONGODB_DB=veritruth_news
MONGODB_URL=mongodb://veritruth:change-me-mongo-password@localhost:27017/veritruth_news

# ── Neo4j (Knowledge Graph) ─────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-neo4j-password

# ── Redis (Cache + Celery Broker) ───────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:change-me-redis-password@localhost:6379/0
CELERY_BROKER_URL=redis://:change-me-redis-password@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:change-me-redis-password@localhost:6379/2

# ── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ── AI Model Paths ──────────────────────────────────────────
MODEL_CACHE_DIR=./models
FAKE_NEWS_MODEL=roberta-base
PROPAGANDA_MODEL=bert-base-uncased
SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest
DEEPFAKE_MODEL=./models/deepfake_cnn.pth
SPACY_MODEL=en_core_web_trf

# ── External APIs ────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
GOOGLE_FACT_CHECK_API_KEY=your-google-factcheck-key

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_ANALYSIS_PER_HOUR=20

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Email (Optional) ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-app-password
